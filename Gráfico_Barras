<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<title>Gráfico de Barras Dinámico</title>
<style>
    body{
        font-family: Arial;
        text-align: center;
    }
    .contenedor{
        display: flex;
        justify-content: center;
        align-items: flex-end;
        height: 300px;
        gap: 10px;
        margin-top: 40px;
    }
    .barra{
        width: 40px;
        background: blue;
        color: white;
        text-align: center;
    }
</style>
</head>
<body>

<h2>Gráfico de Barras Dinámico</h2>

<div class="contenedor" id="grafico"></div>

<script>
const grafico = document.getElementById("grafico");

// crear barras
let barras = [];
for(let i=0; i<5; i++){
    let barra = document.createElement("div");
    barra.classList.add("barra");
    grafico.appendChild(barra);
    barras.push(barra);
}

function actualizar(){
    barras.forEach(barra => {
        let valor = Math.floor(Math.random()*91)+10; // 10-100
        barra.style.height = valor * 2 + "px";
        barra.textContent = valor;
    });
}

setInterval(actualizar, 1000);
actualizar();
</script>

</body>
</html>
